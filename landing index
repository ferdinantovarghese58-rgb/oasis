<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Landing Page</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <!-- HEADER -->
    <header>
        <nav>
            <h2 class="logo">MyBrand</h2>
            <ul>
                <li><a href="#">Home</a></li>
                <li><a href="#">Features</a></li>
                <li><a href="#">About</a></li>
                <li><a href="#">Contact</a></li>
            </ul>
        </nav>

        <div class="hero">
            <h1>Build Your Future with Us</h1>
            <p>Learn web development and design amazing websites.</p>
            <button>Get Started</button>
        </div>
    </header>

    <!-- FEATURES -->
    <section class="features">
        <h2>Our Features</h2>
        <div class="container">
            <div class="box">
                <h3>Fast</h3>
                <p>Optimized for speed and performance.</p>
            </div>
            <div class="box">
                <h3>Responsive</h3>
                <p>Works on all devices.</p>
            </div>
            <div class="box">
                <h3>Easy</h3>
                <p>Simple and beginner friendly.</p>
            </div>
        </div>
    </section>

    <!-- ABOUT -->
    <section class="about">
        <div class="about-text">
            <h2>About Us</h2>
            <p>We help beginners learn web development easily with practical projects.</p>
        </div>
        <div class="about-img">
            <img src="https://via.placeholder.com/400" alt="About Image">
        </div>
    </section>

    <!-- FOOTER -->
    <footer>
        <p>© 2026 MyBrand | All Rights Reserved</p>
    </footer>

</body>
</html>
